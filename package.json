{
  "name": "find-my-agent",
  "private": true,
  "version": "0.1.0",
  "description": "A spatial live-map (Find My-style) for parallel Claude Code agents.",
  "workspaces": [
    "server",
    "client",
    "hooks"
  ],
  "bin": {
    "fma": "cli/fma.ts"
  },
  "scripts": {
    "fma": "bun run cli/fma.ts",
    "build": "bun run --cwd client build",
    "server": "bun run server/src/index.ts",
    "client": "bun run --cwd client dev",
    "hooks:install": "bun run hooks/install.ts",
    "dev": "echo 'Dev: `bun run server` + `bun run client` (Vite/HMR). Users: just `fma`.'"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
